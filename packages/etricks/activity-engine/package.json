{
  "name": "@etricks/activity-engine",
  "version": "0.0.1",
  "private": true,
  "description": "The Universal Activity Engine. One engine, many configurable activity types. Humans build this once; AIOS manufactures the content; every game composes it. See ADR-0024.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test src/**/*.test.ts",
    "bench": "tsx bench/bench.ts",
    "clean": "rimraf dist .turbo"
  },
  "dependencies": {
    "@etricks/contracts": "workspace:*",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
