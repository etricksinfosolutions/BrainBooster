# Brain Booster Kids — WEB CLIENT public config (Vite).
# ONLY non-secret, publishable values belong here. Anything VITE_-prefixed is
# embedded in the client bundle and is world-readable. NEVER put an OAuth client
# SECRET, JWT/session secret, or private key here — those live only in
# server/.env and never reach the browser. See docs/IDENTITY_PLATFORM.md.

# Point the PWA at your live content/API server. When set, the app fetches
# levels, worlds and branding from <VITE_API_BASE>/api/content at startup.
# Leave empty to use the bundled public/content.json (offline-friendly default).
VITE_API_BASE=

# Optional CDN origin for baked sprite assets (empty = bundled/offline).
VITE_CDN_BASE_URL=

# PUBLIC OAuth identifiers (safe to ship). Leave empty until the provider app is
# registered — Cloud Sync then shows "Soon" instead of a broken flow. The
# matching SECRETS live only in server/.env.
VITE_GOOGLE_CLIENT_ID=
VITE_FACEBOOK_APP_ID=
VITE_APPLE_CLIENT_ID=
