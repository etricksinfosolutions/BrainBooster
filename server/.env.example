# Brain Booster Kids — server environment
PORT=4000
DATABASE_URL=postgres://brainbooster:brainbooster@localhost:5432/brainbooster
JWT_SECRET=change-me-to-a-long-random-string
JWT_TTL=2h
CORS_ORIGINS=http://localhost:5173,https://your-domain.example

# Admin portal + OAuth token signing (fall back to JWT_SECRET if unset).
ADMIN_JWT_SECRET=
OAUTH_JWT_SECRET=
OAUTH_ISSUER=brainbooster-oauth

# Seed OAuth client for the web app (client-credentials grant). Must match the
# web app's VITE_WEBAPP_CLIENT_ID / VITE_WEBAPP_CLIENT_SECRET.
WEBAPP_CLIENT_ID=webapp-brainbooster
WEBAPP_CLIENT_SECRET=webapp-dev-secret-change-me
WEBAPP_SCOPE=content,activities
WEBAPP_SESSION_MIN=60

# Razorpay (web payments)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Google Play Billing (service-account JSON path)
GOOGLE_PLAY_SERVICE_ACCOUNT=
ANDROID_PACKAGE_NAME=in.co.etricks.brainboosterkids

# Apple App Store Server API
APPLE_ISSUER_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY_PATH=
